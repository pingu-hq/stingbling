---
import Layout from "../layouts/Layout.astro";
import { User, Shield, Target, MessageSquare } from "@lucide/astro";

const values = [
  {
    icon: Target,
    title: "arozoid",
    color: "var(--primary)",
    desc: '"hey looky here! i\'m a developer"',
  },
  {
    icon: Shield,
    title: "random other person",
    color: "var(--secondary)",
    desc: '"I did research and a lot of other stuff"',
  },
];
---

<Layout title="About Aquatic Docs">
  <section class="animate-fade">
    <div class="about-container">
      <!--<span class="badge">The Mission</span>-->
      <h1 class="header-main">
        StingBling<br /><span class="gradient-text"
          >Jellyfish Documentation</span
        >
      </h1>
      <p class="intro-sub">
        StingBling is a website that documents various jellyfish species in
        Palawan, Philippines. The aim of this project is to inform locals and
        tourists alike about the jellyfish species in the area and how to avoid
        them, and their stings effectively.
      </p>
      <div class="values-section">
        <h2>The Team</h2>
        <div class="values-grid">
          {
            values.map((v) => (
              <div class="value-item">
                <div class="icon-circle">
                  <v.icon size={28} />
                </div>
                <h4>{v.title}</h4>
                <p>{v.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .about-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 6rem 2rem;
  }

  .header-main {
    font-size: clamp(3rem, 8vw, 4rem);
    margin-bottom: 2rem;
  }

  .intro-sub {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin-bottom: 5rem;
    line-height: 1.8;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 6rem;
  }

  .info-card {
    padding: 2.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: white;
  }

  .about-grid h3 {
    font-size: 1.75rem;
    margin-bottom: 1.25rem;
    color: var(--primary);
  }

  .about-grid p {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .values-section {
    text-align: center;
    padding-top: 6rem;
    border-top: 1px solid var(--border);
  }

  .values-section h2 {
    font-size: 2.5rem;
    margin-bottom: 4rem;
  }

  .values-grid {
    display: flex;
    justify-content: center;
    gap: 4rem;
    flex-wrap: wrap;
  }

  .value-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .icon-circle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    background: var(--primary-glow);
    color: var(--primary);
  }

  .value-item h4 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .value-item p {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .values-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
  }
</style>
