---
import "../styles/global.css";
import {
    Home,
    BookOpen,
    User,
    Menu,
    X,
    Search,
    HelpCircle,
} from "@lucide/astro";
import Github from "../components/Github.astro";

interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "StingBling - Comprehensive guide to jellyfish awareness and documentation in El Nido, Palawan.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title} | StingBling El Nido</title>
    </head>
    <body>
        <div
            class="blob"
            style="top: 5%; left: -5%; width: 400px; height: 400px; background: var(--primary);"
        >
        </div>
        <div
            class="blob"
            style="top: 50%; right: -5%; width: 500px; height: 500px; background: var(--secondary); animation-delay: -5s;"
        >
        </div>

        <header class="header">
            <nav class="nav-container">
                <div class="nav-left">
                    <a href="/" class="logo">
                        <div class="logo-icon"></div>
                        <span class="logo-text"
                            >Sting<span class="logo-accent">Bling</span>
                        </span>
                    </a>
                    <div class="search-bar">
                        <Search size={16} />
                        <input
                            type="text"
                            placeholder="Search jellyfish database..."
                        />
                        <kbd>/</kbd>
                    </div>
                </div>

                <div class="nav-links">
                    <a href="/" class="nav-link">
                        <Home size={18} />
                        <span>Home</span>
                    </a>
                    <a href="/blog" class="nav-link">
                        <BookOpen size={18} />
                        <span>Species</span>
                    </a>
                    <a href="/about" class="nav-link">
                        <User size={18} />
                        <span>About</span>
                    </a>
                    <a
                        href="https://github.com/pingu-hq/stingbling"
                        target="_blank"
                        class="github-link"
                    >
                        <Github size={20} />
                    </a>
                </div>

                <button class="menu-toggle" id="menu-toggle">
                    <Menu id="menu-icon" />
                    <X id="close-icon" class="hidden" />
                </button>
            </nav>

            <div class="mobile-menu hidden" id="mobile-menu">
                <a href="/" class="mobile-nav-link"><Home size={20} /> Home</a>
                <a href="/blog" class="mobile-nav-link"
                    ><BookOpen size={20} /> Docs</a
                >
                <a href="/about" class="mobile-nav-link"
                    ><User size={20} /> About</a
                >
            </div>
        </header>

        <main>
            <slot />
        </main>

        <footer class="footer">
            <div class="footer-container">
                <div class="footer-grid">
                    <div class="footer-info">
                        <div class="logo">
                            <div class="logo-icon"></div>
                            <span class="logo-text"
                                >Sting<span class="logo-accent">Bling</span>
                            </span>
                        </div>
                        <p>
                            Protecting locals and tourists by documenting local
                            marine life in El Nido, Palawan.
                        </p>
                    </div>
                    <div class="footer-links-grid">
                        <div class="footer-col">
                            <h4>Documentation</h4>
                            <a href="/blog">Guides</a>
                            <a href="#">Reference</a>
                        </div>
                        <div class="footer-col">
                            <h4>Community</h4>
                            <a href="https://github.com/pingu-hq/stingbling"
                                >GitHub</a
                            >
                            <a href="/about">About Us</a>
                        </div>
                    </div>
                </div>
                <div class="footer-bottom">
                    <p>
                        &copy; 2026 StingBling El Nido. Dedicated to marine
                        safety and education.
                    </p>
                    <p>Powered by Astro & Cloudflare</p>
                </div>
            </div>
        </footer>

        <script>
            const menuToggle = document.getElementById("menu-toggle");
            const mobileMenu = document.getElementById("mobile-menu");
            const menuIcon = document.getElementById("menu-icon");
            const closeIcon = document.getElementById("close-icon");

            menuToggle?.addEventListener("click", () => {
                mobileMenu?.classList.toggle("hidden");
                menuIcon?.classList.toggle("hidden");
                closeIcon?.classList.toggle("hidden");
            });
        </script>
    </body>
</html>

<style is:global>
    .header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
    }

    .nav-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 4.5rem;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 2.5rem;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 800;
        font-size: 1.5rem;
        color: var(--text-main);
    }

    .logo-icon {
        width: 28px;
        height: 28px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        border-radius: 50% 50% 10% 10%;
        position: relative;
    }

    .logo-icon::after {
        content: "";
        position: absolute;
        bottom: -4px;
        left: 20%;
        width: 2px;
        height: 8px;
        background: var(--primary);
        box-shadow: 6px 0 var(--primary), 12px 0 var(--secondary),
            18px 0 var(--secondary);
        border-radius: 2px;
        opacity: 0.5;
    }

    .logo-accent {
        color: var(--primary);
    }

    .search-bar {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(14, 165, 233, 0.05);
        border: 1px solid var(--border);
        padding: 0.5rem 0.75rem;
        border-radius: 0.75rem;
        width: 280px;
        color: var(--text-muted);
        transition: var(--transition);
    }

    .search-bar:focus-within {
        background: #fff;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px var(--primary-glow);
        color: var(--text-main);
    }

    .search-bar input {
        background: transparent;
        border: none;
        outline: none;
        flex: 1;
        font-family: inherit;
        font-size: 0.9rem;
    }

    .search-bar kbd {
        font-size: 0.75rem;
        background: var(--bg-main);
        border: 1px solid var(--border);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        font-weight: 700;
    }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .nav-link {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
        color: var(--text-muted);
        font-size: 0.95rem;
        padding: 0.5rem 0.75rem;
        border-radius: 0.75rem;
    }

    .nav-link:hover {
        color: var(--primary);
        background: var(--primary-glow);
    }

    .github-link {
        color: var(--text-muted);
        padding: 0.5rem;
        border-left: 1px solid var(--border);
        margin-left: 0.5rem;
        padding-left: 1.5rem;
    }

    .github-link:hover {
        color: var(--text-main);
    }

    .footer {
        background: var(--bg-sidebar);
        border-top: 1px solid var(--border);
        padding: 6rem 0 3rem;
        margin-top: 4rem;
        position: relative;
        overflow: hidden;
    }

    .footer-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 2rem;
        position: relative;
        z-index: 1;
    }

    .footer-grid {
        display: grid;
        grid-template-columns: 1.5fr 2fr;
        gap: 4rem;
        margin-bottom: 4rem;
    }

    .footer-info p {
        margin-top: 1.5rem;
        color: var(--text-muted);
        max-width: 300px;
        font-size: 0.95rem;
    }

    .footer-links-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
    }

    .footer-col h4 {
        margin-bottom: 1.5rem;
        font-size: 1rem;
        color: var(--text-main);
    }

    .footer-col a {
        display: block;
        margin-bottom: 0.75rem;
        color: var(--text-muted);
        font-size: 0.95rem;
    }

    .footer-col a:hover {
        color: var(--primary);
    }

    .footer-bottom {
        padding-top: 2rem;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .menu-toggle {
        display: none;
        background: none;
        border: none;
        color: var(--text-main);
        cursor: pointer;
    }

    .hidden {
        display: none !important;
    }

    @media (max-width: 1024px) {
        .search-bar {
            width: 200px;
        }
    }

    @media (max-width: 768px) {
        .nav-links,
        .search-bar {
            display: none;
        }
        .menu-toggle {
            display: block;
        }
        .mobile-menu {
            position: absolute;
            top: 4.5rem;
            left: 0;
            right: 0;
            background: #fff;
            padding: 1.5rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            gap: 1rem;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }
        .footer-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
    }
</style>
